---
const links = [
  { href: "/", label: "Home" },
  { href: "/demo", label: "Gen UI Demo" },
  { href: "/blog", label: "Writing" },
  { href: "/press", label: "Press" },
];
const path = Astro.url.pathname;
---

<header class="border-b" style="border-color: var(--jm-color-border)">
  <nav
    class="mx-auto flex max-w-3xl items-center justify-between px-6 py-4"
    aria-label="Primary"
  >
    <a href="/" class="font-medium no-underline">Jeff Mills</a>
    <ul class="flex gap-6 text-sm">
      {
        links.slice(1).map(({ href, label }) => (
          <li>
            <a
              href={href}
              aria-current={path === href ? "page" : undefined}
              class="no-underline hover:underline"
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
