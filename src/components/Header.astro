---
interface NavLink {
  href: string;
  label: string;
  download?: boolean;
}

const links: NavLink[] = [
  { href: "/about", label: "About" },
  { href: "/projects", label: "Projects" },
  { href: "/blog", label: "Writing" },
  { href: "/press", label: "Press" },
  { href: "/resume", label: "Resume" },
];
const path = Astro.url.pathname;
const isCurrent = (href: string) =>
  path === href || (href !== "/" && path.startsWith(href));
---

<header class="jm-header">
  <div class="jm-header-inner">
    <nav aria-label="Primary">
      <a href="/" class="jm-brand">jeff mills</a>
      <ul>
        {
          links.map(({ href, label, download }) => (
            <li>
              <a
                href={href}
                aria-current={isCurrent(href) ? "page" : undefined}
                download={download}
                class:list={["jm-navlink", { "is-current": isCurrent(href) }]}
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .jm-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--jm-color-bg);
    border-bottom: 1px dashed var(--jm-color-border);
  }

  .jm-header-inner {
    max-width: var(--jm-max-width);
    margin: 0 auto;
    padding: 0.75rem 1rem;
  }

  .jm-header nav {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .jm-brand {
    color: var(--jm-color-accent);
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: lowercase;
  }

  .jm-brand:hover {
    text-decoration: none;
  }

  .jm-header ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 1.25rem;
    font-size: 0.9em;
  }

  .jm-navlink {
    color: var(--jm-color-link);
  }

  .jm-navlink.is-current {
    color: var(--jm-color-accent);
  }

  .jm-navlink.is-current::before {
    content: "> ";
    color: var(--jm-color-muted);
  }
</style>
