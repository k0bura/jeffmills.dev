---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0e0e0e" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:p-2"
      style="background: var(--jm-color-accent); color: var(--jm-color-bg)"
    >
      Skip to content
    </a>
    <div class="crt-overlay" aria-hidden="true">
      <div class="crt-log">
        <pre class="crt-log-inner">{crtLogText}</pre>
      </div>
    </div>
    <div class="jm-shell">
      <Header />
      <main id="main">
        <slot />
      </main>
      <Footer />
    </div>
    <script is:inline>
      (() => {
        const root = document.documentElement;
        let mx = 0,
          my = 0,
          queued = false;
        window.addEventListener(
          "pointermove",
          (e) => {
            if (e.pointerType !== "mouse") return;
            mx = e.clientX;
            my = e.clientY;
            if (!queued) {
              queued = true;
              requestAnimationFrame(() => {
                root.style.setProperty("--mx", mx + "px");
                root.style.setProperty("--my", my + "px");
                queued = false;
              });
            }
          },
          { passive: true }
        );
        window.addEventListener(
          "pointerleave",
          () => {
            root.style.setProperty("--mx", "-1000px");
            root.style.setProperty("--my", "-1000px");
          },
          { passive: true }
        );
      })();
    </script>
  </body>
</html>
