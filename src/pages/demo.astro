---
import Base from "../layouts/Base.astro";
import GenUI from "../demo/GenUI.svelte";
---

<Base title="Gen UI Demo — Jeff Mills" description="Two-stage LLM tool-use pipeline rendering live UI from a prompt.">
  <h1 class="text-3xl font-semibold tracking-tight">Gen UI Demo</h1>
  <p class="mt-4 mb-10" style="color: var(--jm-color-muted)">
    Two Claude tool-use calls in series. The first picks components from a tiny
    web-component library; the second arranges them into a layout. The output
    you see below is what the model rendered for your prompt.
  </p>

  <GenUI client:load />
</Base>
