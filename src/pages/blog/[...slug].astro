---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const dateFmt = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Base title={`${post.data.title} — Jeff Mills`} description={post.data.description}>
  <article class="article">
    <header class="mb-10">
      <h1 class="text-3xl font-semibold tracking-tight m-0">
        {post.data.title}
      </h1>
      <p class="mt-3" style="color: var(--jm-color-muted)">
        {post.data.description}
      </p>
      <p class="mt-4 text-sm" style="color: var(--jm-color-muted)">
        <time datetime={post.data.publishDate.toISOString()}>
          {dateFmt.format(post.data.publishDate)}
        </time>
        {post.data.status === "abstract" && <span> · Abstract — full post in progress</span>}
      </p>
    </header>

    <div class="prose">
      <Content />
    </div>

    <footer class="mt-16 pt-6" style="border-top: 1px solid var(--jm-color-border)">
      <a href="/blog">← All writing</a>
    </footer>
  </article>
</Base>

<style is:global>
  .prose {
    line-height: 1.7;
  }
  .prose > * + * {
    margin-top: 1.25rem;
  }
  .prose h2 {
    font-size: 1.375rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .prose h3 {
    font-size: 1.125rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .prose ul,
  .prose ol {
    padding-left: 1.5rem;
  }
  .prose ul {
    list-style: disc;
  }
  .prose ol {
    list-style: decimal;
  }
  .prose li {
    margin-top: 0.5rem;
  }
  .prose code {
    font-family: var(--jm-font-mono);
    font-size: 0.875em;
    background: var(--jm-color-border);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
  }
  .prose pre {
    background: var(--jm-color-border);
    padding: 1rem;
    border-radius: var(--jm-radius);
    overflow-x: auto;
    font-family: var(--jm-font-mono);
    font-size: 0.875rem;
  }
  .prose pre code {
    background: transparent;
    padding: 0;
  }
  .prose blockquote {
    border-left: 3px solid var(--jm-color-border);
    padding-left: 1rem;
    color: var(--jm-color-muted);
    font-style: italic;
  }
  .prose blockquote > * + * {
    margin-top: 0.75rem;
  }
  .prose a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose strong {
    font-weight: 600;
  }
</style>
