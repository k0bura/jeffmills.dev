---
import Base from "../layouts/Base.astro";

const items = [
  {
    href: "/about",
    label: "About",
    note: "read more",
    summary:
      "20+ years across paradigm shifts. Player-coach. I architected Vanguard's framework-agnostic design system.",
  },
  {
    href: "/case-studies",
    label: "Case Studies",
    note: "the arc",
    summary:
      "Nine years at Vanguard FAS in six chapters: Vue adoption, design-system platform creation, framework-agnostic architecture, AEM integration, governance at scale, and Expert Insights.",
  },
  {
    href: "/projects",
    label: "Projects",
    note: "5 projects",
    summary:
      "Meridian, Anchor, and Skeletor, twelve years of design-system architecture, with architectural overviews. Plus the Gen UI Claude tool-use pipeline and sych0net.",
  },
  {
    href: "/writing",
    label: "Writing",
    note: "6 posts",
    summary:
      "Production notes on design systems, generative UI, MCP, governance, and front-end architecture.",
  },
  {
    href: "/talks",
    label: "Talks",
    note: "2 talks",
    summary:
      "Internal Vanguard co-presentations: the CMS + design-system rebrand story, and Trust at Scale, digitizing Vanguard expertise with GenAI.",
  },
  {
    href: "/press",
    label: "Press",
    note: "8 outlets",
    summary:
      "Coverage of work led at Vanguard FAS, Expert Insights launch, April 2026.",
  },
  {
    href: "mailto:jeffy9@gmail.com",
    label: "Contact",
    note: "email",
    summary: "Reach out about principal front-end work.",
  },
];
---

<Base title="Jeff Mills, Principal Front-End Engineer">
  <section class="hero">
    <h1>jeff mills</h1>
    <p class="role">Principal front-end engineer.</p>
    <p class="bio">
      I'm Jeff Mills, a Principal-level Front-End Engineer with 20+ years of experience, first across Philadelphia agencies and then at Vanguard. The agency work made me fast and Vanguard pushed me to build for scale. I architected Vanguard's framework-agnostic design system, and these days I work hands-on at the intersection of design systems and generative AI. Based in the Philadelphia area.
    </p>
  </section>

  <hr class="jm-rule" />

  <ul class="nav-list">
    {
      items.map(({ href, label, note, summary }) => (
        <li>
          <a href={href} class="row">
            <span class="row-label">{label}</span>
            <span class="row-dots" aria-hidden="true" />
            <span class="row-note">{note}</span>
          </a>
          <p class="row-summary">{summary}</p>
        </li>
      ))
    }
  </ul>
</Base>

<style>
  .hero h1 {
    font-size: 1.5rem;
    text-transform: lowercase;
    letter-spacing: 0.05em;
    margin: 0.5rem 0 0.75rem;
  }

  .role {
    margin: 0;
    color: var(--jm-color-fg);
  }

  .bio {
    margin: 0.5rem 0 0;
    color: var(--jm-color-muted);
  }

  .bio :global(strong) {
    color: var(--jm-color-fg);
    font-weight: 400;
  }

  .nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-list > li {
    margin: 1.25rem 0;
  }

  .row {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    color: var(--jm-color-link);
  }

  .row::before {
    content: ">";
    color: var(--jm-color-muted);
  }

  .row-label {
    color: var(--jm-color-fg);
  }

  .row:hover .row-label,
  .row:hover .row-note {
    color: var(--jm-color-accent);
  }

  .row-dots {
    flex: 1;
    border-bottom: 1px dotted var(--jm-color-border);
    transform: translateY(-0.3em);
    min-width: 1.5rem;
  }

  .row-note {
    color: var(--jm-color-ok);
    font-size: 0.9em;
  }

  .row-summary {
    margin: 0.25rem 0 0 1rem;
    color: var(--jm-color-muted);
    font-size: 0.9em;
  }
</style>
