---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";

export async function getStaticPaths() {
  const posts = await getCollection("writing");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const dateFmt = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Base title={`${post.data.title} — Jeff Mills`} description={post.data.description}>
  <article class="article">
    <header class="post-header">
      <p class="post-meta">
        <time datetime={post.data.publishDate.toISOString()}>
          {dateFmt.format(post.data.publishDate)}
        </time>
        {post.data.status !== "published" && (
          <>
            <span class="meta-sep">&middot;</span>
            <span class="post-status">{post.data.status}</span>
          </>
        )}
      </p>
      <h1 class="post-title">{post.data.title}</h1>
      <p class="post-desc">{post.data.description}</p>
    </header>

    <hr class="jm-rule" />

    <div class="prose">
      <Content />
    </div>

    <hr class="jm-rule" />

    <footer class="post-footer">
      <a href="/writing">&laquo; all writing</a>
    </footer>
  </article>
</Base>

<style is:global>
  .post-header {
    margin-bottom: 1rem;
  }

  .post-meta {
    margin: 0 0 0.5rem;
    color: var(--jm-color-muted);
    font-size: 0.85em;
    display: flex;
    gap: 0.5rem;
    align-items: baseline;
  }

  .post-status {
    color: var(--jm-color-ok);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .meta-sep {
    color: var(--jm-color-border);
  }

  .post-title {
    font-size: 1.5rem;
    font-weight: 400;
    margin: 0 0 0.5rem;
    color: var(--jm-color-accent);
    letter-spacing: 0;
  }

  .post-desc {
    margin: 0;
    color: var(--jm-color-fg);
  }

  .prose {
    line-height: 1.7;
  }
  .prose > * + * {
    margin-top: 1.25rem;
  }
  .prose h2 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--jm-color-accent);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    text-transform: lowercase;
    letter-spacing: 0.04em;
  }
  .prose h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--jm-color-accent);
    margin-top: 1.5rem;
    margin-bottom: 0.4rem;
  }
  .prose ul,
  .prose ol {
    padding-left: 1.5rem;
    list-style: none;
  }
  .prose ul li {
    position: relative;
  }
  .prose ul li::before {
    content: ">";
    color: var(--jm-color-muted);
    position: absolute;
    left: -1.25rem;
  }
  .prose ol {
    counter-reset: jm-ol;
  }
  .prose ol li {
    counter-increment: jm-ol;
    position: relative;
  }
  .prose ol li::before {
    content: counter(jm-ol) ".";
    color: var(--jm-color-muted);
    position: absolute;
    left: -1.5rem;
  }
  .prose li {
    margin-top: 0.4rem;
  }
  .prose code {
    font-family: var(--jm-font-mono);
    font-size: 0.9em;
    background: #1a1a1a;
    padding: 0.1em 0.35em;
  }
  .prose pre {
    background: #1a1a1a;
    padding: 1rem;
    overflow-x: auto;
    font-family: var(--jm-font-mono);
    font-size: 0.875rem;
    border: 1px solid var(--jm-color-border);
  }
  .prose pre code {
    background: transparent;
    padding: 0;
  }
  .prose blockquote {
    border-left: 2px solid var(--jm-color-border);
    padding-left: 1rem;
    color: var(--jm-color-muted);
  }
  .prose a {
    color: var(--jm-color-link);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose a:hover {
    color: var(--jm-color-accent);
  }
  .prose strong {
    color: var(--jm-color-fg);
    font-weight: 700;
  }
  .prose hr {
    border: none;
    border-top: 1px dashed var(--jm-color-border);
    margin: 1.5rem 0;
  }

  .post-footer {
    color: var(--jm-color-muted);
    font-size: 0.9em;
  }
</style>
