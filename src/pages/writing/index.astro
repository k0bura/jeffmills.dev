---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("writing")).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const dateFmt = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<Base title="Writing — Jeff Mills">
  <h1 class="page-title">writing</h1>
  <p class="page-lede">
    Production notes on design systems, generative UI, and front-end
    architecture.
  </p>

  <hr class="jm-rule" />

  <ul class="post-list">
    {
      posts.map((post) => (
        <li>
          <article>
            <header class="post-head">
              <time
                datetime={post.data.publishDate.toISOString()}
                class="post-date"
              >
                {dateFmt.format(post.data.publishDate)}
              </time>
              {post.data.status !== "published" && (
                <span class="post-status">{post.data.status}</span>
              )}
            </header>
            <h2 class="post-title">
              <a href={`/writing/${post.id}`}>{post.data.title}</a>
            </h2>
            <p class="post-desc">{post.data.description}</p>
          </article>
        </li>
      ))
    }
  </ul>
</Base>

<style>
  .page-title {
    font-size: 1.5rem;
    text-transform: lowercase;
    letter-spacing: 0.05em;
    margin: 0.5rem 0 0.5rem;
  }

  .page-lede {
    margin: 0 0 0.5rem;
    color: var(--jm-color-muted);
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-list > li {
    padding: 1rem 0;
    border-bottom: 1px dashed var(--jm-color-border);
  }

  .post-list > li:last-child {
    border-bottom: none;
  }

  .post-head {
    display: flex;
    gap: 0.75rem;
    align-items: baseline;
    font-size: 0.85em;
  }

  .post-date {
    color: var(--jm-color-muted);
  }

  .post-status {
    color: var(--jm-color-ok);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .post-title {
    font-size: 1rem;
    font-weight: 400;
    margin: 0.35rem 0 0.35rem;
    color: var(--jm-color-fg);
  }

  .post-title a {
    color: inherit;
  }

  .post-desc {
    margin: 0;
    color: var(--jm-color-muted);
    font-size: 0.9em;
  }
</style>
