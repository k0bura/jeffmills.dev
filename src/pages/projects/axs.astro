const createComponentSample = `// libs/axs-automation/src/generators/create-component/generator.ts
//
// One Nx command (\`nx generate @axs/axs-automation:create-component\`)
// scaffolds a new component into both axs-vue and axs-web-components,
// with optional usage docs (.mdx) and meta JSON for the AI/IDE
// integration. Reduces the cost of adding a component from "remember
// 12 conventions" to "answer 3 questions". Documentation quality
// becomes the default, not an afterthought.

import { formatFiles, generateFiles, Tree } from "@nx/devkit";
import * as path from "path";
import { CreateComponentSchema } from "./schema";
import { appendToFile, createBaseSubstitutions } from "../../util/utils";

function createFileStucture(
  tree: Tree,
  tplDir: string,
  outputDir: string,
  name: { pascalName: string; kebabName: string; plainName: string },
) {
  generateFiles(tree, tplDir, outputDir, {
    fileName: \`Axs\${name.pascalName}\`,
    name: name.kebabName,
    tpl: name.plainName,
  });
}

export async function createComponentGenerator(
  tree: Tree,
  options: CreateComponentSchema,
) {
  const nameFormat = createBaseSubstitutions(options.name);

  const dirWebTemplates = path.join(__dirname, "files-web-component");
  const dirVueTemplates = path.join(__dirname, "files-vue");

  const dirVueComponentRoot =
    \`libs/axs-vue/src/components/Axs\${nameFormat.pascalName}\`;
  const dirWebComponentRoot =
    \`libs/axs-web-components/src/components/Axs\${nameFormat.pascalName}\`;

  const fileDocs = path.join(
    dirWebComponentRoot,
    \`Axs\${nameFormat.pascalName}Usage.mdx\`,
  );
  const fileMeta = path.join(
    dirWebComponentRoot,
    \`\${nameFormat.kebabName}.meta.json\`,
  );

  // Scaffold both packages from templates
  createFileStucture(tree, dirWebTemplates, dirWebComponentRoot, nameFormat);
  createFileStucture(tree, dirVueTemplates, dirVueComponentRoot, nameFormat);

  if (!options.docs)     tree.delete(fileDocs);
  if (!options.examples) tree.delete(fileMeta);

  // Auto-register the new tag in defineComponents.ts
  appendToFile(
    tree,
    "/libs/axs-web-components/src/defineComponents.ts",
    nameFormat.pascalName,
  );

  await formatFiles(tree);
}

export default createComponentGenerator;`;
