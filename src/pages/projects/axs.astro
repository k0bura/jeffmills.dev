const defineComponentsSample = `// libs/axs-web-components/src/defineComponents.ts
//
// The Vue-to-Web-Components transpilation entry point. Vue 3's
// defineCustomElement wraps each .vue file into a standards-based
// custom element that any framework (or no framework) can render.
// One source, many targets, the architectural premise FASET proved
// at smaller scale, scaled here to ~54 web components shipping into
// 11 product teams.

import { defineCustomElement } from "vue";

import AxsButton from "@axs/axs-vue/src/components/AxsButton/AxsButton.vue";
import AxsCard from "@axs/axs-vue/src/components/AxsCard/AxsCard.vue";
import AxsModal from "@axs/axs-vue/src/components/AxsModal/AxsModal.vue";
import AxsTooltip from "@axs/axs-vue/src/components/AxsTooltip/AxsTooltip.vue";
import AxsAccordion from "@axs/axs-vue/src/components/AxsAccordion/AxsAccordion.vue";
// ... ~50 more

// Register each Vue component as a custom element. Public consumers
// import this file once; any <axs-button>, <axs-card>, etc. in their
// markup gets upgraded automatically.

customElements.define("axs-button",    defineCustomElement(AxsButton));
customElements.define("axs-card",      defineCustomElement(AxsCard));
customElements.define("axs-modal",     defineCustomElement(AxsModal));
customElements.define("axs-tooltip",   defineCustomElement(AxsTooltip));
customElements.define("axs-accordion", defineCustomElement(AxsAccordion));
// ... and so on`;

const jwebTypesSample = `// libs/axs-automation/src/executors/jweb-types/executor.ts
//
// Build-time IDE metadata generator. Parses every Vue SFC with
// vue-docgen-api, extracts props/events/slots, and emits a JetBrains
// web-types JSON schema declared in package.json. Result: every
// editor with the package installed gets autocomplete + hover docs
// for every AXS custom element automatically.
//
// This is the foundation Layer 1 of the AXS + AI architecture
// (see /case-studies/07-axs-ai-architecture). Without this, the
// MCP server has no authoritative metadata to serve.

import { BlockTag, parse, PropDescriptor } from "vue-docgen-api";
import { collect, extractFromProp, getDocumentation } from "../../tool/collector";
import * as path from "node:path";
import * as fs from "node:fs";

export default async function runExecutor(options: JwebTypesExecutorSchema) {
  const collected = await collect();
  const cmp = {};

  console.log("Extracting docs and building map");
  await Promise.all(
    collected.components.map(async (filePath: string) => {
      cmp[filePath.replace(/\\\\/g, "/")] = await extractInformation(
        path.join(collected.root, filePath),
      );
      return true;
    }),
  );
  console.log("Writing web-types to file ", options.out ?? "./");
  await write(Object.values(cmp), options.out ?? "./");

  return { success: true };
}

async function extractInformation(absolutePath: string) {
  const doc = await parse(absolutePath);
  const additional = await findAdditional(absolutePath);
  const { description } = await getDocumentation(doc);

  return {
    tags: [
      {
        // PascalCase → kebab-case: AxsButton → axs-button
        name: doc.displayName
          .replace(/[A-Z]/g, (m) => "-" + m.toLowerCase())
          .substring(1),
        description,
        attributes: doc.props
          ?.map((prop: PropDescriptor) => {
            const { theType, documentationTypeValue } = extractFromProp(prop);

            // Respect @undocumented tag - some props are internal
            if (prop?.tags && Object.keys(prop?.tags).includes("undocumented")) {
              return undefined;
            }

            return {
              name: prop.name.replace(/[A-Z]/g, (m) => "-" + m.toLowerCase()),
              description: prop.description
                ? prop.description + " (type: " + documentationTypeValue + ")"
                : "type: " + documentationTypeValue,
              value: { type: Array.isArray(theType) ? theType.join(" | ") : theType },
              defaultValue: prop.defaultValue?.value ?? "undefined",
              required: prop?.tags && Object.keys(prop?.tags).includes("required"),
            };
          })
          .filter((q) => !!q),

        // Events + slots get the same treatment
        js: {
          events: doc.events?.map((event) => ({
            name: event.name,
            description: event.description,
          })),
        },
        slots: doc.slots?.map((slot) => ({
          name: slot.name,
          description: slot.description,
          required: slot?.tags && Object.keys(slot?.tags).includes("required"),
        })),

        ...additional, // optional sidecar AxsButtonDoc.json with manual overrides
      },
    ],
  };
}`;

const foundationDiff = `// nx.json, added in the founding commit, April 27 2022.
// The monorepo configuration the next two years of work was built on.

{
  "npmScope": "axs",
  "affected": { "defaultBase": "master" },
  "cli": { "defaultCollection": "@nrwl/workspace" },
  "implicitDependencies": {
    "package.json": {
      "dependencies": "*",
      "devDependencies": "*"
    }
  },
  "tasksRunnerOptions": {
    "default": {
      "runner": "@nrwl/workspace/tasks-runners/default",
      "options": {
        "cacheableOperations": ["build", "lint", "test", "e2e"]
