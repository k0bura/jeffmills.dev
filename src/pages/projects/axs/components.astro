const composables = [
  "attribute", "binder", "deeplySlottedElement", "domElement",
  "horizontalScroll", "hostElement", "notifier", "propSync", "request",
  "resize", "slotElement", "slottedElements", "smoothScroll", "viewport",
];

const featured = new Set(["AxsButton", "AxsAccordion"]);

const renderTreeLine = (name: string, mark: boolean): string => {
  const featuredMark = mark
    ? '  <span class="featured-marker">[&dagger;]</span>'
    : "";
  const classAttr = mark ? ' class="featured"' : "";
  return `<span${classAttr}>├── ${name}</span>${featuredMark}`;
};

const axsVueTreeHtml =
  "libs/axs-vue/src/components/\n" +
  axsVue.map((c) => renderTreeLine(c, featured.has(c))).join("\n");

const axsWcTreeHtml =
  "libs/axs-web-components/src/components/\n" +
  axsWc.map((c) => renderTreeLine(c, false)).join("\n");

const composablesTreeHtml =
  "libs/axs-vue/src/composables/\n" +
  composables.map((c) => renderTreeLine(c, c === "viewport")).join("\n");

const axsButtonSample = `<!-- libs/axs-vue/src/components/AxsButton/AxsButton.vue -->
<!-- Vue 3 script setup with TypeScript. Compiled to a custom
     element via defineCustomElement. Same component used by
     Vue consumers directly and by Angular/AEM/raw HTML through
     the custom element wrapper. -->

<template>
  <component
    :is="props.axsLink ? 'a' : 'button'"
    :id="buttonId"
    ref="buttonElement"
    :href="props.axsLink"
    :class="[
      'axs-button',
      \`axs-button--\${props.axsType}\`,
      \`axs-button--\${props.axsType}-\${props.axsSize}\`,
      \`axs-button--\${props.axsType}-\${props.axsTheme}\`,
      { 'axs-button--protected': props.axsProtected },
      props.axsIconLeft
        ? \`axs-button--\${props.axsType}-icon-left\`
        : \`axs-button--\${props.axsType}-icon-right\`,
      { 'axs-button--disabled': props.axsIsDisabled },
    ]"
    :target="isTargetBlank ? '_blank' : null"
    :aria-label="ariaLabel"
    :aria-controls="props.axsAriaControls"
    :aria-expanded="props.axsAriaExpanded"
    :aria-disabled="props.axsIsDisabled"
    @click="onClick"
    @keydown="onKeyDown"
  >
    <AxsIcon
      v-if="iconLeft"
      class="axs-button__icon"
      :axs-type="props.axsIconType"
      :axs-decorative="true"
    />
    <span v-if="showText" class="axs-button__text" v-html="props.axsText" />
    <AxsIcon
      v-if="iconRight"
      class="axs-button__icon"
      :axs-type="props.axsIconType"
      :axs-decorative="true"
    />
  </component>
</template>

<script setup lang="ts">
  import { ref, computed } from "vue";
  import { uniqueId } from "lodash-es";

  import AxsIcon from "../AxsIcon/AxsIcon.vue";
  import { vClickOutside } from "../../directives";

  import {
    IconType,
    ButtonType, ButtonTheme, ButtonSize, ButtonNativeType,
  } from "@axs/axs-core";

  // TypeScript Props interface drives both the component API
  // and (via vue-docgen-api) the IDE metadata exported through
  // the axs-automation:jweb-types executor.
  interface Props {
    /** Button design types. TS enum: \`ButtonType\`. */
    axsType?: ButtonType;
    /** Button text. */
    axsText?: string;
    /** Link target. Renders as <a> when set. */
    axsLink?: string;
    /** Button sizes. TS enum: \`ButtonSize\`. */
    axsSize?: ButtonSize;
    /** Button color theme. TS enum: \`ButtonTheme\`. */
    axsTheme?: ButtonTheme;
    /** Icon position. */
    axsIconLeft?: boolean;
    /** Icon type. TS enum: \`IconType\`. */
    axsIconType?: IconType;
    /** Disabled state (uses aria-disabled, not the native attribute). */
    axsIsDisabled?: boolean;
    /** Accessibility label. */
    axsAriaLabel?: string;
    /** ID of the element this button controls. */
    axsAriaControls?: string;
    /** Expanded state for accordion/disclosure buttons. */
    axsAriaExpanded?: boolean;
    // ... etc
  }

  const props = withDefaults(defineProps<Props>(), {
    axsType: ButtonType.primary,
    axsTheme: ButtonTheme.red,
    axsSize: ButtonSize.large,
  });

  const buttonId = computed(() => props.axsCustomId ?? uniqueId("axs-button-"));
  // ... event handlers, computed classes, focus/hover/tooltip wiring
</script>`;

const axsAccordionSample = `<!-- libs/axs-vue/src/components/AxsAccordion/
            AxsAccordionController.vue -->
<!-- A tiny component that demonstrates the V1 composable layer.
     useHostElement + useDeeplySlottedElement + useDOMElement are
     reactive abstractions over shadow DOM that handle the
     normally-awkward "find my parent custom element" /
     "find my slotted trigger" /  "talk to an external element"
     patterns. -->

<template>
  <slot @click.prevent="clicked" />
</template>

<script setup lang="ts">
  import { computed, reactive } from "vue";
  import { uniqueId } from "lodash-es";

  import { useDOMElement } from "../../composables/domElement";
  import { useHostElement } from "../../composables/hostElement";
  import { useDeeplySlottedElement } from "../../composables/deeplySlottedElement";
  import { AccordionPanelProperty } from "./types";

  interface Props {
    /** ID of the accordion this controller drives. */
    axsFor?: string;
  }

  const props = withDefaults(defineProps<Props>(), { axsFor: undefined });

  const labelData = reactive<{ [key: string]: string | undefined }>({
    id: uniqueId("axs-accordion-controller-"),
  });

  // The custom-element host that wraps this Vue component.
  // Reactive read/write of attributes on the wrapping <axs-accordion-controller>.
  const self = useHostElement();

  self.watchAttributes(() => {
    self.setPolitely("id", labelData.id);
  });

  // Find the slotted axs-accordion-trigger anywhere in the subtree
  // and wire it up to point back at this controller's id.
  const trigger = useDeeplySlottedElement("", "axs-accordion-trigger");

  trigger.watchAttributes(() => {
    trigger.setPolitely("axs-parent", self.attrRef["id"]);
  });

  // The indicator (chevron) gets its direction from the target
  // accordion's open state. Reactive cross-element binding.
  const indicator = useDeeplySlottedElement("", "axs-indicator");
  const accordion = useDOMElement(computed(() => props.axsFor));

  accordion.watchAttributes(() => {
    indicator.attrRef["axs-direction"] =
      accordion.getBool(AccordionPanelProperty.openedState) ? "up" : "down";
  });

  function clicked(event: Event) {
    self.notifyElement(\`#\${props.axsFor}\`, "requestToggle");
  }
</script>`;

const useViewportSample = `// libs/axs-vue/src/composables/viewport/index.ts
//
// One reactive viewport object per consumer, fed by five
// matchMedia listeners. Consumers can computed/watch off it like
// any reactive Vue 3 state. Replaces the FASET-era v-show-at /
// v-hide-at directives with a hook that works the same in
// templates, render functions, or computed properties.

import { reactive } from "vue";
import { Breakpoints } from "@axs/axs-core";

export const useViewport = () => {
  const viewport = reactive({
    isSmall:   false,
    isMedium:  false,
    isLarge:   false,
    isXlarge:  false,
    isXxlarge: false,
  });

  const mqlSmall = window.matchMedia(
    \`(max-width: \${Breakpoints.md - 1}px)\`
  );
  const mqlMedium = window.matchMedia(
    \`(min-width: \${Breakpoints.md}px) and (max-width: \${Breakpoints.lg - 1}px)\`
  );
  const mqlLarge = window.matchMedia(
    \`(min-width: \${Breakpoints.lg}px) and (max-width: \${Breakpoints.xlg - 1}px)\`
  );
  const mqlXlarge = window.matchMedia(
    \`(min-width: \${Breakpoints.xlg}px) and (max-width: \${Breakpoints.xxlg - 1}px)\`
  );
  const mqlXxlarge = window.matchMedia(
    \`(min-width: \${Breakpoints.xxlg}px)\`
  );

  const onMqlChange = () => {
    viewport.isSmall   = mqlSmall.matches;
    viewport.isMedium  = mqlMedium.matches;
    viewport.isLarge   = mqlLarge.matches;
    viewport.isXlarge  = mqlXlarge.matches;
    viewport.isXxlarge = mqlXxlarge.matches;
  };

  mqlSmall.addEventListener("change", onMqlChange);
  mqlMedium.addEventListener("change", onMqlChange);
  mqlLarge.addEventListener("change", onMqlChange);
  mqlXlarge.addEventListener("change", onMqlChange);
  mqlXxlarge.addEventListener("change", onMqlChange);
  onMqlChange();

  return viewport;
};`;
