---
import { Code } from "astro:components";
import Base from "../../../layouts/Base.astro";
import syntaxTheme from "../../../styles/jm-syntax.json";

const theme = syntaxTheme as unknown as Parameters<typeof Code>[0]["theme"];

const TYPE_BREAKDOWN: { label: string; count: number; max: number }[] = [
  { label: "feat", count: 38, max: 40 },
  { label: "chore", count: 34, max: 40 },
  { label: "fix", count: 24, max: 40 },
  { label: "build", count: 11, max: 40 },
  { label: "refactor", count: 9, max: 40 },
  { label: "docs", count: 9, max: 40 },
  { label: "ci", count: 5, max: 40 },
  { label: "test", count: 3, max: 40 },
  { label: "style", count: 3, max: 40 },
];

const bar = (n: number, max: number) => {
  const width = Math.round((n / max) * 32);
  return "█".repeat(width) + "·".repeat(32 - width);
};

const breakdownLines = TYPE_BREAKDOWN.map(
  (t) => `${t.label.padEnd(9, " ")}  ${bar(t.count, t.max)}  ${t.count}`,
).join("\n");

// Commit 1: foundation
const nxJsonDiff = `// nx.json, newly added (April 27, 2022)
{
  "npmScope": "axs",
  "affected": { "defaultBase": "master" },
  "cli": { "defaultCollection": "@nrwl/workspace" },
  "implicitDependencies": {
    "package.json": {
      "dependencies": "*",
      "devDependencies": "*"
    }
  },
  "tasksRunnerOptions": {
    "default": {
      "runner": "@nrwl/workspace/tasks-runners/default",
      "options": {
        "cacheableOperations": ["build", "lint", "test", "e2e"]
      }
    }
  }
}`;

const packageJsonExcerpt = `// package.json, devDependencies (excerpt, scrubbed)
{
  "devDependencies": {
    "@nrwl/cli":              "13.9.3",
    "@nrwl/workspace":        "13.9.3",
    "@nrwl/storybook":        "^13.9.6",
    "@nrwl/web":              "^13.9.6",
    "@storybook/vue3":        "^6.4.18",
    "@vitejs/plugin-vue":     "^2.2.2",
    "@vue/eslint-config-typescript": "^10.0.0",
    "@vue/tsconfig":          "^0.1.3",
    "vite":                   "^2.8.4",
    "vite-tsconfig-paths":    "^3.4.0",
    "vitest":                 "^0.10.0",
    "vue":                    "^3.2.31",
    "vue-tsc":                "^0.34.10",
    "typescript":             "~4.5.5"
  }
}`;

// Commit 2: storybook with vite
const storybookMainDiff = `// .storybook/main.js, added April 29, 2022 (two days after the foundation)
//
// Storybook with the Vite builder, when the default was still
// Webpack. The team got HMR-fast Storybook from day one.

module.exports = {
  core: { builder: "@storybook/builder-vite" },
  stories: [],
  addons: [
    "@storybook/addon-links",
    "@storybook/addon-essentials",
    // Doesn't work with Vite (yet)
    // "@storybook/addon-a11y"
  ],
};`;

// Commit 3: lint + format hooks
const huskyPreCommitDiff = `# .husky/pre-commit, added with the lint refactor
npx lint-staged

# .lintstagedrc.json
{
  "*.{js,ts,vue}": ["eslint --fix"],
  "*.{js,ts,vue,scss,css,md,json}": ["prettier --write"]
}

# .prettierrc (excerpt)
{
  "useTabs": true,
  "tabWidth": 2,
  "printWidth": 80,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "es5"
}`;

// Commit 4: changelog wiring
const changelogProjectJson = `// libs/axs-vue/project.json, added in the changelog commit
// Wires @jscutlery/semver into each library so versions and
// CHANGELOG.md are generated from conventional commits.

{
  "targets": {
    "version": {
      "executor": "@jscutlery/semver:version",
      "options": {
        "preset": "conventional",
        "tagPrefix": "axs-vue-",
        "trackDeps": true,
        "noVerify": true,
        "push": true,
        "skipProjectChangelog": false,
        "postTargets": ["axs-vue:github-release"]
      }
    }
  }
}`;

// Commit 5: CSS compositions enable
const cssCompositionsDiff = `// libs/axs-core/src/styles/main.scss, June 27, 2023
//
// One-line change. Enabled compositions across the entire design
// system, utility-first style primitives become available to every
// consumer of axs-core. Small diff, foundational consequence.

  /// COMPOSITIONS
- // @use "./compositions/" as c;
+ @use "./compositions/" as c;`;
---

<Base
  title="AXS commits, Jeff Mills"
  description="Verified commit gallery: 159 commits authored across the AXS monorepo, April 2022, March 2024. Foundational Nx setup, Storybook + Vite, lint hooks, changelog tooling, design-token plumbing."
>
  <p class="project-back"><a href="/projects/axs">&laquo; back to axs</a></p>
  <h1 class="page-title">axs &middot; verified commits</h1>
  <p class="project-meta">
    <span class="project-year">apr 2022, mar 2024</span>
    <span class="meta-sep">&middot;</span>
    <span class="project-status">159 commits</span>
    <span class="meta-sep">&middot;</span>
    <span>jeff mills</span>
  </p>

  <p class="page-lede">
    159 commits authored by me, drawn directly from the AXS repository&rsquo;s
    git history. Below: the contribution profile, then six featured commits
    with hash, file-change counts, and scrubbed diff excerpts. Hashes are
    real; package namespaces and internal ticket IDs have been removed.
  </p>

  <aside class="callout">
    <span class="callout-label">Proprietary, sample diffs only</span>
    <p>
      Each diff below is a real excerpt from the source repository,
      scrubbed of corporate identifiers. The hashes are unmodified.
      I&rsquo;m happy to walk through the full diffs side-by-side
      under NDA,
      <a href="mailto:jeffy9@gmail.com">reach out</a>.
    </p>
  </aside>

  <hr class="jm-rule" />

  <h2 class="section-title">contribution profile</h2>
  <p class="section-lede">
    Conventional-commit type breakdown across all 159 commits.
  </p>

  <pre class="type-chart">{breakdownLines}</pre>

  <p class="profile-note">
    The shape tells a story: heavy on <code>feat</code> and
    <code>chore</code> means the work was platform-level, not
    ticket-by-ticket. Storybook integration, monorepo plumbing, release
    tooling, lint/format hooks, the infrastructure decisions that
    let the rest of the team move.
  </p>

  <hr class="jm-rule" />

  <h2 class="section-title">featured commits</h2>

  <article class="commit-block">
    <div class="commit-card-head">
      <code class="commit-hash">75773a774</code>
      <span class="commit-date">2022-04-27</span>
      <span class="commit-stats">36 files &middot; +34,043 / &minus;12</span>
    </div>
    <p class="commit-msg">
      <code>chore</code>: working nx structure with vue/vite/ts
    </p>
    <p class="commit-note">
      <strong>The foundational commit.</strong> Stood up the entire Nx
      monorepo with Vue 3, Vite, TypeScript, Storybook, ESLint, the
      structure the next 9,000+ commits in the repo were built on. The
      design system&rsquo;s build pipeline, the project-tagging conventions,
      the cacheable task runner, all here.
    </p>

    <Code code={nxJsonDiff} lang="javascript" theme={theme} />
    <p class="caption"><code>nx.json</code> (added)</p>

    <Code code={packageJsonExcerpt} lang="json" theme={theme} />
    <p class="caption"><code>package.json</code> &middot; devDependencies excerpt</p>
  </article>

  <hr class="jm-rule" />

  <article class="commit-block">
    <div class="commit-card-head">
      <code class="commit-hash">5a73ed8b4</code>
      <span class="commit-date">2022-04-29</span>
      <span class="commit-stats">3 files &middot; +10,010 / &minus;7,102</span>
    </div>
    <p class="commit-msg">
      <code>feat(storybook)</code>: add storybook with vite builder
    </p>
    <p class="commit-note">
      Two days after the foundation, Storybook landed, configured
      with the Vite builder when the default everywhere else was still
      Webpack. The team got HMR-fast Storybook from day one and never
      had to migrate later.
    </p>

    <Code code={storybookMainDiff} lang="javascript" theme={theme} />
    <p class="caption"><code>.storybook/main.js</code> (added)</p>
  </article>

  <hr class="jm-rule" />

  <article class="commit-block">
    <div class="commit-card-head">
      <code class="commit-hash">aefebfcbd</code>
      <span class="commit-date">2022-05-05</span>
      <span class="commit-stats">10 files &middot; lint config + husky hooks</span>
    </div>
    <p class="commit-msg">
      <code>refactor(lint)</code>: lint and formatting hooks
    </p>
    <p class="commit-note">
      Husky + lint-staged + Prettier + ESLint, wired into the commit
      lifecycle for the whole monorepo. Code quality enforced at write
      time, not in review, the most leveraged thing a platform
      engineer can ship in the first month.
    </p>

    <Code code={huskyPreCommitDiff} lang="bash" theme={theme} />
    <p class="caption">
      <code>.husky/pre-commit</code>, <code>.lintstagedrc.json</code>,
      <code>.prettierrc</code> (added)
    </p>
  </article>

  <hr class="jm-rule" />

  <article class="commit-block">
    <div class="commit-card-head">
      <code class="commit-hash">e8025695b</code>
      <span class="commit-date">2023-05-23</span>
      <span class="commit-stats">9 files &middot; release tooling wired across 4 libraries</span>
    </div>
    <p class="commit-msg">
      <code>feat(changelog)</code>: initial changelog script
    </p>
    <p class="commit-note">
      Wired <code>@jscutlery/semver</code> into every library&rsquo;s
      <code>project.json</code>, with conventional-commit parsing and
      per-library tag prefixes. Every CHANGELOG entry in the repo from
      this commit forward is produced by this pipeline.
    </p>

    <Code code={changelogProjectJson} lang="json" theme={theme} />
    <p class="caption">
      <code>libs/axs-vue/project.json</code> &middot; version target added
    </p>
  </article>

  <hr class="jm-rule" />

  <article class="commit-block">
    <div class="commit-card-head">
      <code class="commit-hash">7cb4c660b</code>
      <span class="commit-date">2023-06-27</span>
      <span class="commit-stats">1 file &middot; +1 / &minus;1</span>
    </div>
    <p class="commit-msg">
      <code>feat(css)</code>: add compositions to main.scss
    </p>
    <p class="commit-note">
      <strong>One line.</strong> Foundational consequence: enabled CSS
      compositions across the entire design system. Utility-first style
      primitives became available to every consumer of axs-core. Small
      diffs that move large abstractions are a senior signal.
    </p>

    <Code code={cssCompositionsDiff} lang="scss" theme={theme} />
    <p class="caption">
      <code>libs/axs-core/src/styles/main.scss</code> &middot; one-line
      enable
    </p>
  </article>

  <hr class="jm-rule" />

  <article class="commit-block">
    <div class="commit-card-head">
      <code class="commit-hash">49d963e80</code>
      <span class="commit-date">2022-08-23</span>
      <span class="commit-stats">2 files &middot; AEM CI integration</span>
    </div>
    <p class="commit-msg">
      <code>fix(axs-aem-app)</code>: pin AEM build to node14
    </p>
    <p class="commit-note">
      One of nine commits I authored on the <code>axs-aem-app</code>
      surface, the integration that lets AEM templates consume AXS
      components as web components (the
      <a href="/case-studies/04-axs-aem-integration">Building the AEM
      bridge</a> case study). Pinning the build runtime so the AEM
      pipeline produced stable artifacts across teammate machines.
    </p>
    <p class="commit-note-secondary">
      Diff intentionally omitted, the AEM-side configuration
      includes deployment specifics. Happy to walk through under NDA.
    </p>
  </article>

  <hr class="jm-rule" />

  <p class="project-foot">
    Back to <a href="/projects/axs">AXS overview</a>
    &middot; <a href="/projects/axs/components">Component browser</a>
    &middot; <a href="/case-studies/02-building-axs">Building AXS
    (case study)</a>
  </p>
</Base>

<style>
  .project-back {
    margin: 0 0 0.75rem;
    font-size: 0.85em;
    color: var(--jm-color-muted);
  }

  .page-title {
    font-size: 1.5rem;
    text-transform: lowercase;
    letter-spacing: 0.05em;
    margin: 0.25rem 0 0.4rem;
  }

  .project-meta {
    margin: 0 0 1rem;
    font-size: 0.85em;
    color: var(--jm-color-muted);
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: baseline;
  }

  .project-meta .project-year {
    color: var(--jm-color-fg);
  }

  .project-meta .project-status {
    color: var(--jm-color-accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700;
  }

  .meta-sep {
    color: var(--jm-color-border);
  }

  .page-lede {
    margin: 0 0 1rem;
    color: var(--jm-color-fg);
  }

  .section-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--jm-color-accent);
    text-transform: lowercase;
    letter-spacing: 0.05em;
    margin: 2.25rem 0 0.5rem;
  }

  .section-lede {
    margin: 0 0 0.75rem;
    color: var(--jm-color-muted);
    font-size: 0.95em;
  }

  .type-chart {
    background: transparent;
    border: 1px dashed var(--jm-color-border);
    padding: 1rem 1.25rem;
    margin: 0.5rem 0 0;
    color: var(--jm-color-accent);
    font-family: var(--jm-font-mono);
    font-size: 0.85rem;
    line-height: 1.55;
    overflow-x: auto;
  }

  .profile-note {
    margin: 1rem 0 0;
    color: var(--jm-color-muted);
    font-size: 0.95em;
  }

  .commit-block {
    margin: 1.5rem 0 0;
  }

  .commit-card-head {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    align-items: baseline;
    font-size: 0.85em;
    padding: 0.5rem 0.75rem;
    border-left: 2px solid var(--jm-color-accent);
    background: rgba(255, 204, 0, 0.04);
  }

  .commit-hash {
    color: var(--jm-color-accent);
    background: transparent;
    padding: 0;
    font-weight: 700;
    letter-spacing: 0.04em;
    font-family: var(--jm-font-mono);
  }

  .commit-date {
    color: var(--jm-color-muted);
  }

  .commit-stats {
    color: var(--jm-color-ok);
    font-family: var(--jm-font-mono);
  }

  .commit-msg {
    margin: 0.4rem 0 0.3rem;
    color: var(--jm-color-fg);
    font-family: var(--jm-font-mono);
    font-size: 0.95em;
  }

  .commit-msg code {
    color: var(--jm-color-accent);
    background: transparent;
    padding: 0;
    font-weight: 700;
  }

  .commit-note {
    margin: 0.25rem 0 0;
    color: var(--jm-color-muted);
    font-size: 0.9em;
    line-height: 1.6;
  }

  .commit-note strong {
    color: var(--jm-color-fg);
    font-weight: 700;
  }

  .commit-note-secondary {
    margin: 0.5rem 0 0;
    padding: 0.4rem 0.75rem;
    border-left: 1px dashed var(--jm-color-dim);
    color: var(--jm-color-dim);
    font-style: italic;
    font-size: 0.85em;
  }

  .caption {
    margin: 0.35rem 0 0;
    color: var(--jm-color-dim);
    font-size: 0.8em;
  }

  .caption code {
    background: transparent;
    color: var(--jm-color-muted);
    padding: 0;
  }

  code {
    font-family: var(--jm-font-mono);
    font-size: 0.9em;
    background: #1a1a1a;
    padding: 0.1em 0.35em;
  }

  :global(.astro-code) {
    border: 1px solid var(--jm-color-border) !important;
    padding: 1rem !important;
    font-family: var(--jm-font-mono) !important;
    font-size: 0.78rem !important;
    line-height: 1.55 !important;
    overflow-x: auto;
    margin: 0.5rem 0 0;
  }

  :global(.astro-code code) {
    background: transparent !important;
    padding: 0 !important;
    font-size: inherit !important;
  }

  .project-foot {
    margin: 2rem 0 0;
    color: var(--jm-color-muted);
    font-size: 0.9em;
  }
</style>
